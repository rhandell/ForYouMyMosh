<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Monthsary 💜</title>

    <link rel="stylesheet" href="style.css">
</head>

<body>

    <!-- 🌸 DREAMY BACKGROUND LAYER -->
    <div class="bg"></div>

    <!-- 💜 MAIN -->
    <div class="container">

        <div id="envelope" onclick="openEnvelope()">

            <div class="letter"></div>

            <div class="front"></div>
            <div class="flap"></div>
            <div class="left"></div>
            <div class="right"></div>

            <div class="seal">💜</div>

        </div>

        <div id="hint">💜 Click the envelope 💜</div>

    </div>

    <!-- 💌 MESSAGE -->
    <div id="message">

        <h2>HAPPY MONTHSARY MOSH 💜</h2>

        <p id="typingText"></p>

        <h3>
            🌸 No matter how many months pass,
            I’ll still choose you always MOSH. 🌸
        </h3>

    </div>

    <script src="script.js"></script>

</body>

</html>
